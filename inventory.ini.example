# Copy this file to inventory.ini and configure your servers
#
# cp inventory.ini.example inventory.ini

[claude_servers]
# Add your servers here:
# server-name ansible_host=IP_ADDRESS ansible_user=root

# Example:
# my-server ansible_host=1.2.3.4 ansible_user=root

# Override git config per host:
# my-server ansible_host=1.2.3.4 ansible_user=root host_git_user_name="Your Name" host_git_user_email="your@email.com"

# Or per group (applies to all servers):
# [claude_servers:vars]
# host_git_user_name=Your Name
# host_git_user_email=your@email.com
